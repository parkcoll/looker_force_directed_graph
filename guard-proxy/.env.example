# Public HTTPS URL of this service (e.g. https://your-app.up.railway.app)
PUBLIC_URL=https://example.up.railway.app

# Google OAuth client (create at https://console.cloud.google.com/apis/credentials)
# Add ${PUBLIC_URL}/auth/google/callback to authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Picker API config.
# 1. Enable "Google Picker API" in the same Cloud project.
# 2. Create an API key in Credentials. Restrict to HTTP referrers: ${PUBLIC_URL}/*
# 3. App ID is the numeric project number (Cloud Console → Project Settings).
GOOGLE_API_KEY=
GOOGLE_APP_ID=

# Long random string. Used as a query param to gate the approvals page.
APPROVAL_PAGE_SECRET=

# Where to store the SQLite file. Use a mounted volume in prod.
DB_PATH=./data.db

# Railway sets PORT automatically.
PORT=3000
